{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LANCAST",
  "version": "1.0.0",
  "identifier": "in.sambhavdwivedi.lancast",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "LANCAST",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "© 2026 Sambhav Dwivedi",
    "category": "Utility",
    "shortDescription": "Encrypted LAN communication",
    "longDescription": "Instant, end-to-end encrypted communication between devices on the same Wi-Fi network. Zero cloud. Zero servers. Zero accounts. Zero traces.",
    "windows": {
      "digestAlgorithm": "sha256",
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
